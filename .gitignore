*~
bin/
disks/
*.o
*.dsk
*.sna

# Local reference disk dumps — not redistributable.
/Original CPM Boot Disks/

# Ignore user-dropped ROM blobs; keep README and any committed tools.
roms/*
!roms/*.ROM
!roms/*.rom
!roms/README*

# dist tarballs produced by `make dist`
/1985-*.tar.gz

# Windows build output dirs
/dist-win*/

# autotools — generated by ./configure or make, not committed
/Makefile
/config.status
/config.log
/src/.deps/
/src/.dirstamp
/1985
/autom4te.cache/

# Runtime screenshots and F6 captures
1985_*.ppm
1985-*.ppm
1985-*.gif

# Flatpak build output
/flatpak-repo/
/1985.flatpak
/Emulator1985-*.flatpak
/local-repo/
/repo/

# Autotools regenerable bits not tracked elsewhere
/build-aux/config.guess
/build-aux/config.sub
/config.h.in
/Makefile.in
/aclocal.m4
/configure
/configure~
