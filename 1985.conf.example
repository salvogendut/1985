# 1985 — Amstrad PCW 8256 emulator configuration
#
# This file is auto-created at ~/.config/1985/1985.conf on first run.
# The F9 overlay edits it in place.

[machine]
model = 8256
memory_kb = 256
# pal (50 Hz, 256 lines) / ntsc (60 Hz, top 200 lines, F8 bit 4 set)
region = pal
# false = stock 4 MHz Z80; true = 8 MHz overclock (CP/M apps run ~2× faster)
turbo = false

[storage]
drive_a =
drive_b =

[display]
scale = 2
fullscreen = false
fullscreen_smoothing = true
# Lightweight CRT post-process. real_crt enables the Advanced overlay controls.
real_crt = false
# Scanline opacity, 0..95. Brightness is 50..100.
# Contrast and RGB channel gains are 50..150.
crt_scanlines = 35
crt_brightness = 100
crt_contrast = 100
crt_red = 100
crt_green = 100
crt_blue = 100
# off / green / amber / white. PCW shipped with a green-phosphor monitor.
monochrome = green

[extensions]
ext_second_drive        = false
ext_sanpollo_backplane  = false
ext_serial              = false
ext_serial_backend      = pty
ext_serial_tcp_port     = 4002
ext_perryfi             = false
# hayes / perrynet. Hayes stays compatible with terminal software;
# PerryNet is a framed socket API for new CP/M software.
perryfi_mode            = hayes
ext_dktronics           = false
input_device            = joystick
ext_pdf_printer         = false
ext_pdf_printer_dir     =

[advanced]
# Set tinker=true to unlock the Advanced tab in the F9 overlay.
tinker = false
# Animated GIF profile used by F6 and --gif-out. Resolutions preserve the
# PCW display's corrected 4:3 aspect ratio; FFmpeg optimization is optional.
gif_resolution = 720x540
gif_fps = 25
gif_ffmpeg = false
# false crops the guest's bottom 8 scanlines (CP/M status row), like a
# real CRT's overscan — on real hardware that row is never visible.
status_line = true
# screen = fading toast over PCW display; console = stderr line; off = silent
notifications = screen
# Web GUI: serve the emulator screen + controls over HTTP.
# Binds 0.0.0.0 — anyone on your network can view and type. No auth.
web_gui = false
web_port = 1985
debug = false
debug_traces = false
trace_io = false
trace_fdc = false
trace_input = false
# amx / kempston / keymouse (keyboard overlay, MicroDesign 3)
mouse_type = amx
# dksound (AY r14 / port A9) / kempston (port 9F)
# cascade (port E0, active-low) / spectravideo (port E0, active-high)
# keyboard (kbd-MCU chord bytes on 3FFC-3FFF, e.g. Opera Soft games)
joystick_type = dksound
