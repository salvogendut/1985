# 1985 — Amstrad PCW 8256 emulator configuration
#
# This file is auto-created at ~/.config/1985/1985.conf on first run.
# The F9 overlay edits it in place.

[machine]
model = 8256
memory_kb = 256

[storage]
drive_a =
drive_b =

[display]
scale = 2
fullscreen = false
fullscreen_smoothing = true
# off / green / amber / white. PCW shipped with a green-phosphor monitor.
monochrome = green

[extensions]
ext_second_drive        = false
ext_sanpollo_backplane  = false
ext_serial              = false
ext_serial_backend      = pty
ext_serial_tcp_port     = 4002
ext_perryfi             = false
ext_dktronics           = false
input_device            = joystick
ext_pdf_printer         = false
ext_pdf_printer_dir     =

[advanced]
# Set tinker=true to unlock the Advanced tab in the F9 overlay.
tinker = false
debug = false
debug_traces = false
trace_io = false
trace_fdc = false
trace_input = false
# amx / kempston / keymouse (keyboard overlay, MicroDesign 3)
mouse_type = amx
# dksound (AY r14 / port A9) / kempston (port 9F)
# cascade (port E0, active-low) / spectravideo (port E0, active-high)
joystick_type = dksound
